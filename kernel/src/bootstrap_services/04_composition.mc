func execute_composition_service_fan_out(config: CompositionServiceConfig, execution: CompositionServiceExecutionState) CompositionServiceExecutionResult {
    request_payload: [4]u8 = ipc.zero_payload()
    request_payload[0] = config.request_byte0
    request_payload[1] = config.request_byte1

    init_request_send: syscall.SendResult = syscall.perform_send(execution.gate, execution.init_handle_table, execution.endpoints, config.init_pid, syscall.build_send_request(config.init_control_handle_slot, 2, request_payload))
    next_state: CompositionServiceExecutionState = CompositionServiceExecutionState{ program_capability: execution.program_capability, gate: init_request_send.gate, process_slots: execution.process_slots, task_slots: execution.task_slots, init_handle_table: init_request_send.handle_table, child_handle_table: execution.child_handle_table, wait_table: execution.wait_table, endpoints: init_request_send.endpoints, init_image: execution.init_image, child_address_space: execution.child_address_space, child_user_frame: execution.child_user_frame, echo_peer_state: execution.echo_peer_state, log_peer_state: execution.log_peer_state, spawn_observation: execution.spawn_observation, request_receive_observation: execution.request_receive_observation, echo_fanout_observation: execution.echo_fanout_observation, echo_peer_receive_observation: execution.echo_peer_receive_observation, echo_reply_send_observation: execution.echo_reply_send_observation, echo_reply_observation: execution.echo_reply_observation, log_fanout_observation: execution.log_fanout_observation, log_peer_receive_observation: execution.log_peer_receive_observation, log_ack_send_observation: execution.log_ack_send_observation, log_ack_observation: execution.log_ack_observation, aggregate_reply_send_observation: execution.aggregate_reply_send_observation, aggregate_reply_observation: execution.aggregate_reply_observation, wait_observation: execution.wait_observation, observation: execution.observation, ready_queue: execution.ready_queue }
    if syscall.status_score(init_request_send.status) != 2 {
        return composition_service_result(next_state, 0)
    }
    return execute_composition_service_queued_request(config, next_state)
}

func simulate_composition_service_exit(config: CompositionServiceConfig, execution: CompositionServiceExecutionState) CompositionServiceExecutionState {
    processes: [3]state.ProcessSlot = lifecycle.exit_process(execution.process_slots, 2)
    tasks: [3]state.TaskSlot = lifecycle.exit_task(execution.task_slots, 2)
    wait_table: capability.WaitTable = capability.mark_wait_handle_exited(execution.wait_table, config.child_pid, config.exit_code)
    return CompositionServiceExecutionState{ program_capability: execution.program_capability, gate: execution.gate, process_slots: processes, task_slots: tasks, init_handle_table: execution.init_handle_table, child_handle_table: execution.child_handle_table, wait_table: wait_table, endpoints: execution.endpoints, init_image: execution.init_image, child_address_space: execution.child_address_space, child_user_frame: execution.child_user_frame, echo_peer_state: execution.echo_peer_state, log_peer_state: execution.log_peer_state, spawn_observation: execution.spawn_observation, request_receive_observation: execution.request_receive_observation, echo_fanout_observation: execution.echo_fanout_observation, echo_peer_receive_observation: execution.echo_peer_receive_observation, echo_reply_send_observation: execution.echo_reply_send_observation, echo_reply_observation: execution.echo_reply_observation, log_fanout_observation: execution.log_fanout_observation, log_peer_receive_observation: execution.log_peer_receive_observation, log_ack_send_observation: execution.log_ack_send_observation, log_ack_observation: execution.log_ack_observation, aggregate_reply_send_observation: execution.aggregate_reply_send_observation, aggregate_reply_observation: execution.aggregate_reply_observation, wait_observation: execution.wait_observation, observation: execution.observation, ready_queue: state.empty_queue() }
}

func execute_phase131_fan_out_composition(config: CompositionServiceConfig, execution: CompositionServiceExecutionState) CompositionServiceExecutionResult {
    next_state: CompositionServiceExecutionState = seed_composition_service_program_capability(config, execution)
    if !capability.is_program_capability(next_state.program_capability) {
        return composition_service_result(next_state, 0)
    }

    spawned: CompositionServiceExecutionResult = spawn_composition_service(config, next_state)
    if spawned.succeeded == 0 {
        return spawned
    }

    relayed: CompositionServiceExecutionResult = execute_composition_service_fan_out(config, spawned.state)
    if relayed.succeeded == 0 {
        return relayed
    }

    next_state = simulate_composition_service_exit(config, relayed.state)
    wait_result: syscall.WaitResult = syscall.perform_wait(next_state.gate, next_state.process_slots, next_state.task_slots, next_state.wait_table, syscall.build_wait_request(config.wait_handle_slot))
    next_state = CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: wait_result.gate, process_slots: wait_result.process_slots, task_slots: wait_result.task_slots, init_handle_table: next_state.init_handle_table, child_handle_table: capability.empty_handle_table(), wait_table: wait_result.wait_table, endpoints: next_state.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: next_state.echo_peer_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: wait_result.observation, observation: next_state.observation, ready_queue: state.empty_queue() }
    if syscall.status_score(next_state.wait_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }
    return composition_service_result(next_state, 1)
}