func prepare_composition_service_local_execution(config: CompositionServiceConfig, execution: CompositionServiceExecutionState) CompositionServiceExecutionState {
    next_state: CompositionServiceExecutionState = ensure_composition_peer_endpoints(config, execution)
    child_handles: capability.HandleTable = capability.install_endpoint_handle(next_state.child_handle_table, config.child_control_handle_slot, config.control_endpoint_id, 3)
    child_handles = capability.install_endpoint_handle(child_handles, config.child_echo_handle_slot, config.echo_endpoint_id, 3)
    child_handles = capability.install_endpoint_handle(child_handles, config.child_log_handle_slot, config.log_endpoint_id, 3)
    return CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: next_state.gate, process_slots: next_state.process_slots, task_slots: next_state.task_slots, init_handle_table: next_state.init_handle_table, child_handle_table: child_handles, wait_table: next_state.wait_table, endpoints: next_state.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: next_state.echo_peer_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: next_state.ready_queue }
}

func spawn_composition_service(config: CompositionServiceConfig, execution: CompositionServiceExecutionState) CompositionServiceExecutionResult {
    next_state: CompositionServiceExecutionState = ensure_composition_peer_endpoints(config, execution)
    if capability.find_endpoint_for_handle(next_state.init_handle_table, config.init_control_handle_slot) != config.control_endpoint_id {
        return composition_service_result(next_state, 0)
    }
    if capability.find_endpoint_for_handle(next_state.init_handle_table, config.init_echo_handle_slot) != config.echo_endpoint_id {
        return composition_service_result(next_state, 0)
    }
    if capability.find_endpoint_for_handle(next_state.init_handle_table, config.init_log_handle_slot) != config.log_endpoint_id {
        return composition_service_result(next_state, 0)
    }

    child_handles: capability.HandleTable = capability.handle_table_for_owner(config.child_pid)
    wait_table: capability.WaitTable = capability.wait_table_for_owner(config.init_pid)
    spawn_request: syscall.SpawnRequest = syscall.build_spawn_request(config.wait_handle_slot)
    spawn_result: syscall.SpawnResult = syscall.perform_spawn(next_state.gate, next_state.program_capability, next_state.process_slots, next_state.task_slots, wait_table, next_state.init_image, spawn_request, config.child_pid, config.child_tid, config.child_asid, config.child_translation_root)
    child_handles = capability.install_endpoint_handle(child_handles, config.child_control_handle_slot, config.control_endpoint_id, 3)
    child_handles = capability.install_endpoint_handle(child_handles, config.child_echo_handle_slot, config.echo_endpoint_id, 3)
    child_handles = capability.install_endpoint_handle(child_handles, config.child_log_handle_slot, config.log_endpoint_id, 3)
    next_state = CompositionServiceExecutionState{ program_capability: spawn_result.program_capability, gate: spawn_result.gate, process_slots: spawn_result.process_slots, task_slots: spawn_result.task_slots, init_handle_table: next_state.init_handle_table, child_handle_table: child_handles, wait_table: spawn_result.wait_table, endpoints: next_state.endpoints, init_image: next_state.init_image, child_address_space: spawn_result.child_address_space, child_user_frame: spawn_result.child_frame, echo_peer_state: next_state.echo_peer_state, log_peer_state: next_state.log_peer_state, spawn_observation: spawn_result.observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: state.user_ready_queue(config.child_tid) }
    if syscall.status_score(next_state.spawn_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }
    if capability.find_endpoint_for_handle(next_state.child_handle_table, config.child_control_handle_slot) != config.control_endpoint_id {
        return composition_service_result(next_state, 0)
    }
    if capability.find_endpoint_for_handle(next_state.child_handle_table, config.child_echo_handle_slot) != config.echo_endpoint_id {
        return composition_service_result(next_state, 0)
    }
    if capability.find_endpoint_for_handle(next_state.child_handle_table, config.child_log_handle_slot) != config.log_endpoint_id {
        return composition_service_result(next_state, 0)
    }
    return composition_service_result(next_state, 1)
}

func build_composition_reply_payload(config: CompositionServiceConfig, echo_reply: syscall.ReceiveObservation, log_ack: syscall.ReceiveObservation) [4]u8 {
    payload: [4]u8 = ipc.zero_payload()
    payload[0] = echo_reply.payload[0]
    payload[1] = echo_reply.payload[1]
    payload[2] = log_ack.payload[0]
    payload[3] = config.edge_count
    return payload
}

func execute_composition_service_queued_request(config: CompositionServiceConfig, execution: CompositionServiceExecutionState) CompositionServiceExecutionResult {
    next_state: CompositionServiceExecutionState = execution
    request_receive: syscall.ReceiveResult = syscall.perform_receive(next_state.gate, next_state.child_handle_table, next_state.endpoints, syscall.build_receive_request(config.child_control_handle_slot))
    next_state = CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: request_receive.gate, process_slots: next_state.process_slots, task_slots: next_state.task_slots, init_handle_table: next_state.init_handle_table, child_handle_table: request_receive.handle_table, wait_table: next_state.wait_table, endpoints: request_receive.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: next_state.echo_peer_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: request_receive.observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: next_state.ready_queue }
    if syscall.status_score(next_state.request_receive_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }

    echo_send: syscall.SendResult = syscall.perform_send(next_state.gate, next_state.child_handle_table, next_state.endpoints, config.child_pid, syscall.build_send_request(config.child_echo_handle_slot, 2, next_state.request_receive_observation.payload))
    next_state = CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: echo_send.gate, process_slots: next_state.process_slots, task_slots: next_state.task_slots, init_handle_table: next_state.init_handle_table, child_handle_table: echo_send.handle_table, wait_table: next_state.wait_table, endpoints: echo_send.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: next_state.echo_peer_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: echo_send.observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: next_state.ready_queue }
    if syscall.status_score(next_state.echo_fanout_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }

    echo_peer_receive: syscall.ReceiveResult = syscall.perform_receive(next_state.gate, next_state.init_handle_table, next_state.endpoints, syscall.build_receive_request(config.init_echo_handle_slot))
    peer_echo_state: echo_service.EchoServiceState = echo_service.record_request(next_state.echo_peer_state, echo_peer_receive.observation)
    next_state = CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: echo_peer_receive.gate, process_slots: next_state.process_slots, task_slots: next_state.task_slots, init_handle_table: echo_peer_receive.handle_table, child_handle_table: next_state.child_handle_table, wait_table: next_state.wait_table, endpoints: echo_peer_receive.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: peer_echo_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: echo_peer_receive.observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: next_state.ready_queue }
    if syscall.status_score(next_state.echo_peer_receive_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }

    echo_reply_send: syscall.SendResult = syscall.perform_send(next_state.gate, next_state.init_handle_table, next_state.endpoints, config.init_pid, syscall.build_send_request(config.init_echo_handle_slot, 2, echo_service.reply_payload(next_state.echo_peer_state)))
    next_state = CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: echo_reply_send.gate, process_slots: next_state.process_slots, task_slots: next_state.task_slots, init_handle_table: echo_reply_send.handle_table, child_handle_table: next_state.child_handle_table, wait_table: next_state.wait_table, endpoints: echo_reply_send.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: next_state.echo_peer_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: echo_reply_send.observation, echo_reply_observation: next_state.echo_reply_observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: next_state.ready_queue }
    if syscall.status_score(next_state.echo_reply_send_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }

    echo_reply_receive: syscall.ReceiveResult = syscall.perform_receive(next_state.gate, next_state.child_handle_table, next_state.endpoints, syscall.build_receive_request(config.child_echo_handle_slot))
    peer_echo_state = echo_service.record_reply(next_state.echo_peer_state, echo_reply_receive.observation)
    next_state = CompositionServiceExecutionState{ program_capability: next_state.program_capability, gate: echo_reply_receive.gate, process_slots: next_state.process_slots, task_slots: next_state.task_slots, init_handle_table: next_state.init_handle_table, child_handle_table: echo_reply_receive.handle_table, wait_table: next_state.wait_table, endpoints: echo_reply_receive.endpoints, init_image: next_state.init_image, child_address_space: next_state.child_address_space, child_user_frame: next_state.child_user_frame, echo_peer_state: peer_echo_state, log_peer_state: next_state.log_peer_state, spawn_observation: next_state.spawn_observation, request_receive_observation: next_state.request_receive_observation, echo_fanout_observation: next_state.echo_fanout_observation, echo_peer_receive_observation: next_state.echo_peer_receive_observation, echo_reply_send_observation: next_state.echo_reply_send_observation, echo_reply_observation: echo_reply_receive.observation, log_fanout_observation: next_state.log_fanout_observation, log_peer_receive_observation: next_state.log_peer_receive_observation, log_ack_send_observation: next_state.log_ack_send_observation, log_ack_observation: next_state.log_ack_observation, aggregate_reply_send_observation: next_state.aggregate_reply_send_observation, aggregate_reply_observation: next_state.aggregate_reply_observation, wait_observation: next_state.wait_observation, observation: next_state.observation, ready_queue: next_state.ready_queue }
    if syscall.status_score(next_state.echo_reply_observation.status) != 2 {
        return composition_service_result(next_state, 0)
    }

    log_payload: [4]u8 = ipc.zero_payload()
